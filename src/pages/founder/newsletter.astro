---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Newsletter | SHAIL Lab',
  description: 'Subscribe to the SHAIL Lab newsletter to receive lab news, research updates, events, and publication highlights.',
};

const FORMSPREE_FORM_ID = 'xvzokooo';
const success = Astro.url.searchParams.get('success') === 'true';
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-3xl px-4 py-16 sm:py-20">

    <!-- Header -->
    <div class="text-center">
      <p class="text-sm font-semibold tracking-wide text-accent uppercase">Stay Connected</p>
      <h1 class="mt-2 text-3xl sm:text-4xl font-bold tracking-tight text-gray-900 dark:text-white">
        Subscribe to the SHAIL Lab Newsletter
      </h1>
      <p class="mt-3 text-base leading-relaxed text-gray-600 dark:text-gray-300 max-w-xl mx-auto">
        Receive updates on lab news, research publications, upcoming events, and innovation highlights — delivered directly to your inbox.
      </p>
    </div>

    <!-- What you'll receive -->
    <ul class="mt-8 mx-auto max-w-xl space-y-3 text-base text-gray-700 dark:text-gray-300 list-disc list-inside">
      <li>New research publications and conference highlights</li>
      <li>Lab news, team announcements, and milestones</li>
      <li>Upcoming events, workshops, and seminars</li>
      <li>Collaboration and student opportunity notices</li>
    </ul>

    <!-- Success message -->
    {success && (
      <div
        class="mt-8 rounded-2xl border border-emerald-200 bg-emerald-50 px-5 py-4 text-sm text-emerald-900
               dark:border-emerald-900/40 dark:bg-emerald-950/20 dark:text-emerald-200"
        role="status"
        aria-live="polite"
      >
        <p class="font-semibold">Thank you for subscribing!</p>
        <p class="mt-1">You're now on the SHAIL Lab newsletter list. You can unsubscribe at any time by replying to any email.</p>
      </div>
    )}

    <!-- Form -->
    <div class="mt-10 rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-slate-900 sm:p-10">
      <form
        method="POST"
        action={`https://formspree.io/f/${FORMSPREE_FORM_ID}`}
        class="space-y-6"
      >
        <!-- Formspree metadata -->
        <input type="hidden" name="_subject" value="New Newsletter Subscription – SHAIL Lab" />
        <input type="hidden" name="_template" value="table" />
        <input type="hidden" name="_redirect" value="/founder/newsletter?success=true" />
        <input type="hidden" name="type" value="newsletter_subscription" />

        <!-- Name -->
        <div>
          <label for="name" class="mb-2 block text-sm font-medium text-gray-900 dark:text-white">
            Full name <span class="text-red-500">*</span>
          </label>
          <input
            id="name"
            name="name"
            type="text"
            required
            autocomplete="name"
            placeholder="e.g., Jane Smith"
            class="field"
          />
        </div>

        <!-- Email -->
        <div>
          <label for="email" class="mb-2 block text-sm font-medium text-gray-900 dark:text-white">
            Email address <span class="text-red-500">*</span>
          </label>
          <input
            id="email"
            name="email"
            type="email"
            required
            autocomplete="email"
            placeholder="e.g., name@example.com"
            class="field"
          />
        </div>

        <!-- Affiliation (optional) -->
        <div>
          <label for="affiliation" class="mb-2 block text-sm font-medium text-gray-900 dark:text-white">
            Institutional / organization affiliation <span class="text-gray-400 text-xs">(optional)</span>
          </label>
          <input
            id="affiliation"
            name="affiliation"
            type="text"
            autocomplete="organization"
            placeholder="e.g., National Taipei University"
            class="field"
          />
        </div>

        <!-- Consent -->
        <div class="rounded-2xl border border-gray-200 bg-gray-50 p-5 dark:border-gray-800 dark:bg-slate-950 space-y-3">
          <label class="flex gap-3 text-sm text-gray-700 dark:text-gray-300">
            <input
              type="checkbox"
              name="consent_newsletter"
              required
              class="mt-1 h-4 w-4 rounded border-gray-300 text-accent focus:ring-accent"
            />
            <span>
              I agree to receive occasional newsletters from SHAIL Lab and consent to my data being processed for this purpose.
              I understand I can unsubscribe at any time.
              <span class="text-red-500"> *</span>
            </span>
          </label>

          <label class="flex gap-3 text-sm text-gray-700 dark:text-gray-300">
            <input
              type="checkbox"
              name="agree_privacy"
              required
              class="mt-1 h-4 w-4 rounded border-gray-300 text-accent focus:ring-accent"
            />
            <span>
              I have read and agree to the
              <a href="/founder/privacy" class="font-medium text-accent underline underline-offset-4">Privacy Policy</a>.
              <span class="text-red-500"> *</span>
            </span>
          </label>
        </div>

        <!-- Submit -->
        <div class="flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
          <button type="submit" class="btn btn-primary">Subscribe</button>
          <button type="reset" class="btn btn-secondary">Clear</button>
        </div>

        <p class="text-center text-sm text-gray-500 dark:text-gray-400">
          We respect your privacy. No spam — only meaningful lab updates.
        </p>
      </form>
    </div>

  </section>
</Layout>

<style>
  .field {
    width: 100%;
    border-radius: 0.9rem;
    border: 1px solid rgb(209 213 219);
    background: #fff;
    padding: 0.8rem 1rem;
    font-size: 0.95rem;
    line-height: 1.25rem;
    transition: box-shadow 180ms ease, border-color 180ms ease, background 180ms ease;
    outline: none;
  }
  .field:focus {
    border-color: rgba(47, 62, 151, 0.65);
    box-shadow: 0 0 0 4px rgba(47, 62, 151, 0.15);
  }
  .field::placeholder {
    color: rgb(156 163 175);
  }
  :global(.dark) .field {
    background: rgb(2 6 23);
    border-color: rgb(55 65 81);
    color: #fff;
  }
  :global(.dark) .field::placeholder {
    color: rgb(148 163 184);
  }
  :global(.dark) .field:focus {
    border-color: rgba(100, 120, 220, 0.7);
    box-shadow: 0 0 0 4px rgba(100, 120, 220, 0.18);
  }

  .btn {
    border-radius: 0.85rem;
    padding: 0.8rem 1.6rem;
    font-weight: 700;
    font-size: 0.95rem;
    transition: transform 120ms ease, opacity 120ms ease, box-shadow 180ms ease;
  }
  .btn:active {
    transform: translateY(1px);
  }
  .btn-primary {
    background: #2f3e97;
    color: #fff;
    box-shadow: 0 10px 25px rgba(47, 62, 151, 0.25);
  }
  .btn-primary:hover {
    opacity: 0.9;
  }
  .btn-secondary {
    background: transparent;
    color: #2f3e97;
    border: 1px solid rgba(47, 62, 151, 0.45);
  }
  .btn-secondary:hover {
    box-shadow: 0 0 0 4px rgba(47, 62, 151, 0.14);
  }
  :global(.dark) .btn-secondary {
    color: rgb(130, 150, 230);
    border-color: rgba(130, 150, 230, 0.45);
  }
</style>
