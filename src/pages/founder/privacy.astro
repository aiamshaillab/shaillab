---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Privacy Policy | SHAIL Lab',
  description:
    'Privacy Policy for SHAIL Lab (Smart, Health, AI, and Leadership Lab), affiliated with ICSI, National Taipei University (NTPU).',
};

const effectiveDate = '2025-10-20'; // YYYY-MM-DD
const contactEmail = 'aiamshaillab@gmail.com';

const sections = [
  {
    title: 'Information We Collect',
    body: `
      <p>We may collect the following categories of information:</p>
      <ul class="list-disc pl-5 space-y-2 mt-3">
        <li>
          <strong>Personal Information:</strong> Name, email address, institutional affiliation, and other details you
          voluntarily provide through forms, email, or contact pages.
        </li>
        <li>
          <strong>Technical Information:</strong> IP address, browser type, device information, pages visited, and usage
          data collected via cookies, server logs, or analytics tools.
        </li>
        <li>
          <strong>Event &amp; Collaboration Data:</strong> Information provided when registering for events, seminars, or
          collaborative activities, including participation records where relevant.
        </li>
      </ul>
    `,
  },
  {
    title: 'How We Use Information',
    body: `
      <p>We use the collected information to:</p>
      <ul class="list-disc pl-5 space-y-2 mt-3">
        <li>Respond to your enquiries and communicate with you.</li>
        <li>Provide academic, research, and event-related updates when requested.</li>
        <li>Maintain, operate, and improve our website functionality and user experience.</li>
        <li>Support institutional reporting and comply with applicable legal obligations.</li>
      </ul>
    `,
  },
  {
    title: 'Data Sharing',
    body: `
      <p>We do not sell or rent your personal information. We may share information only when necessary with:</p>
      <ul class="list-disc pl-5 space-y-2 mt-3">
        <li><strong>Institutional partners or collaborators</strong> for legitimate academic or research purposes.</li>
        <li>
          <strong>Service providers</strong> that support website hosting, analytics, email delivery, or communications
          (acting under appropriate confidentiality and security obligations).
        </li>
        <li><strong>Authorities</strong> where disclosure is required by law, regulation, or lawful request.</li>
      </ul>
    `,
  },
  {
    title: 'Cookies and Analytics',
    body: `
      <p>
        Our website may use cookies and analytical tools to enhance user experience and gather statistical data.
        You may disable cookies via your browser settings; however, some website features may not function properly.
      </p>
    `,
  },
  {
    title: 'Data Protection and Security',
    body: `
      <p>
        We implement reasonable technical and administrative measures to protect personal data against unauthorized
        access, disclosure, alteration, or destruction. Despite these efforts, no online transmission or storage system
        can be guaranteed to be 100% secure.
      </p>
    `,
  },
  {
    title: 'Your Rights',
    body: `
      <p>Depending on applicable laws, you may have the right to:</p>
      <ul class="list-disc pl-5 space-y-2 mt-3">
        <li>Access and correct your personal data.</li>
        <li>Request deletion of your personal data, where applicable.</li>
        <li>Withdraw consent where processing is based on consent.</li>
      </ul>
      <p class="mt-3">
        To submit a request, contact us at
        <a class="font-semibold text-accent underline underline-offset-4" href="mailto:${contactEmail}">${contactEmail}</a>.
      </p>
    `,
  },
  {
    title: 'International Data Transfer',
    body: `
      <p>
        As part of international academic collaborations, data may be transferred and processed outside your jurisdiction.
        Where applicable, SHAIL Lab will take reasonable steps to ensure appropriate safeguards are in place to protect
        your information.
      </p>
    `,
  },
  {
    title: 'Changes to This Policy',
    body: `
      <p>
        SHAIL Lab may update this Privacy Policy from time to time. Updates will be published on this page with a revised
        effective date.
      </p>
    `,
  },
  {
    title: 'Contact Us',
    body: `
      <p>If you have questions about this Privacy Policy or your personal data, please contact:</p>

      <div class="mt-4 rounded-2xl border border-gray-200 bg-white p-5 text-sm dark:border-gray-800 dark:bg-slate-900">
        <p class="text-gray-800 dark:text-gray-200">
          <span class="font-semibold">Email:</span>
          <a class="ml-1 font-semibold text-accent underline underline-offset-4" href="mailto:${contactEmail}">${contactEmail}</a>
        </p>
        <p class="mt-2 text-gray-800 dark:text-gray-200">
          <span class="font-semibold">Affiliation:</span>
          International College of Sustainability Innovations (ICSI), National Taipei University (NTPU)
        </p>
      </div>
    `,
  },
];
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-4xl px-4 py-14 sm:py-16">
    <!-- Header -->
    <header class="text-center">
      <p class="text-sm font-semibold tracking-wide text-accent">Legal</p>

      <h1 class="mt-2 text-3xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-4xl">
        Privacy Policy
      </h1>

      <p class="mt-3 text-sm text-gray-700 dark:text-gray-300">
        <span class="font-semibold">Effective Date:</span>
        <time datetime={effectiveDate} class="ml-1">{effectiveDate}</time>
      </p>

      <p class="mt-6 text-base leading-relaxed text-gray-800 dark:text-gray-200">
        SHAIL Lab respects and protects your privacy. This Privacy Policy explains how we collect, use, disclose, and
        safeguard your personal data when you visit our website or interact with us.
      </p>
    </header>

    <!-- Divider -->
    <div class="mt-10 border-t border-gray-200 dark:border-gray-800"></div>

    <!-- Accordion -->
    <div class="mt-6">
      {sections.map((s, idx) => (
        <details class="legal-item border-b border-gray-200 dark:border-gray-800 py-5">
          <summary class="flex items-start gap-4 cursor-pointer list-none select-none">
            <span class="mt-0.5 inline-flex h-10 w-10 items-center justify-center rounded-full bg-gray-100 text-gray-900 dark:bg-slate-800 dark:text-white">
              <span class="icon-plus text-lg leading-none">+</span>
              <span class="icon-minus text-lg leading-none">−</span>
            </span>

            <div class="flex-1">
              <h2 class="text-base sm:text-lg font-semibold text-gray-900 dark:text-white">
                {idx + 1}. {s.title}
              </h2>

              <div class="answer mt-3 text-sm sm:text-base leading-relaxed text-gray-700 dark:text-gray-300">
                <Fragment set:html={s.body} />
              </div>
            </div>
          </summary>
        </details>
      ))}
    </div>

    <p class="mt-8 text-center text-xs text-gray-500 dark:text-gray-400">
      This website is for informational and academic purposes only. It does not provide medical or legal advice.
    </p>
  </section>
</Layout>

<style>
  summary::-webkit-details-marker { display: none; }

  .legal-item .answer { display: none; }
  .legal-item[open] .answer { display: block; }

  .icon-minus { display: none; }
  .legal-item[open] .icon-plus { display: none; }
  .legal-item[open] .icon-minus { display: inline; }
</style>
