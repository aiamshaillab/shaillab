    <div class="mt-16 text-center">
      <h3 class="text-xl font-semibold mb-4">Full Publication List</h3>

      <p class="text-gray-600 dark:text-gray-300">
        Additional publications and citation records can be accessed through the following academic profiles.
      </p>

      <div class="mt-4 space-x-6">
        <a href="https://orcid.org/0000-0002-8750-3721" target="_blank" class="text-accent hover:underline">
          ORCID Profile
        </a>

        <a
          href="https://www.scopus.com/authid/detail.uri?authorId=57195972825"
          target="_blank"
          class="text-accent hover:underline"
        >
          Scopus Author Profile
        </a>
      </div>
      <!-- Publications Information Card -->
      <div class="mt-16 max-w-3xl mx-auto">
        <div class="rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900 p-6 shadow-sm">
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-3">
            <strong>Last Updated:</strong> October 2025
          </p>

          <p class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed">
            <strong>Note:</strong> The publications listed on this page include selected peer-reviewed journal articles,delivered
            by the Founder of the
            <strong>Smart, Health, AI, and Leadership Lab (SHAIL Lab)</strong>. Ongoing research works, manuscripts
            under review, and forthcoming publications are not included in this list.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
