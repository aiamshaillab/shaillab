---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Conferences & Invited Talks | SHAIL Lab',
};
---

<Layout metadata={metadata}>
  <section class="max-w-5xl mx-auto px-6 py-20">
    <!-- Page Title -->
    <h1 class="text-4xl font-bold text-center mb-6">Conferences, Guest Lectures & Invited Talks</h1>

    <p class="text-center text-gray-600 dark:text-gray-300 mb-14 max-w-3xl mx-auto">
      This page highlights selected international conference presentations, invited talks, and guest lectures delivered
      by the
      <strong>Founder of the Smart, Health, AI, and Leadership Lab (SHAIL Lab)</strong>, Dr. Yankuba B. Manga.
    </p>

    <!-- Conference List -->
    <div class="space-y-10">
      <!-- Item 1 -->
      <div class="border-l-4 border-accent pl-6">
        <p class="text-gray-800 dark:text-gray-200">
          <strong>Manga, Y. B.</strong> (2025). AI Applications in Healthcare, Medicine, and Public Health.
        </p>
        <p class="text-sm text-gray-500">
          Surabaya · 28 October 2025 · Online · <em>Guest Lecturer</em>
        </p>
      </div>

      <!-- Item 2 -->
      <div class="border-l-4 border-accent pl-6">
        <p class="text-gray-800 dark:text-gray-200">
          <strong>Manga, Y. B.</strong> (2025). ICORE 2025 International Conference on Computing, Research, and Engineering.
        </p>
        <p class="text-sm text-gray-500">
          Institute of Technology Al-Mahrisiyyah Lirboyo · Kediri, Indonesia ·
          <em>Guest Speaker</em>
        </p>
      </div>

      <!-- Item 3 -->
      <div class="border-l-4 border-accent pl-6">
        <p class="text-gray-800 dark:text-gray-200">
          Elmi, K. H., Wu, C.-E., & <strong>Manga, Y. B.</strong> (2025). Reversing sarcopenia with wearable-assisted walking
          in older adults.
        </p>
        <p class="text-sm text-gray-500">UHIMA & TLCMA Symposium · Kaohsiung</p>
      </div>

      <!-- Item 4 -->
      <div class="border-l-4 border-accent pl-6">
        <p class="text-gray-800 dark:text-gray-200">
          Bianchini, G., Adeel, M., & <strong>Manga, Y. B.</strong> (2025). AI in emergency care decision-making: A systematic
          review.
        </p>
        <p class="text-sm text-gray-500">UHIMA & TLCMA Symposium · Kaohsiung</p>
      </div>

      <!-- Item 5 -->
      <div class="border-l-4 border-accent pl-6">
        <p class="text-gray-800 dark:text-gray-200">
          Mai, X. H., Duong-Cao, T. T., & <strong>Manga, Y. B.</strong> (2024). Breast cancer diagnosis via MATLAB pre-trained
          models.
        </p>
        <p class="text-sm text-gray-500">ISQua 2024 · Istanbul</p>
      </div>

      <!-- Item 6 -->
      <div class="border-l-4 border-accent pl-6">
        <p class="text-gray-800 dark:text-gray-200">
          Pawarti, H., Adeel, M., & <strong>Manga, Y. B.</strong> (2024). Digital transformation in cosmeceutical skincare:
          Gap mapping.
        </p>
        <p class="text-sm text-gray-500">FAPA 2024 · Seoul</p>
      </div>

      <!-- Item 7 -->
      <div class="border-l-4 border-accent pl-6">
        <p class="text-gray-800 dark:text-gray-200">
          Mai, H., Cao, T., & <strong>Manga, Y. B.</strong> (2024). MATLAB-based breast cancer assessment.
        </p>
        <p class="text-sm text-gray-500">Value in Health · 27(6), S283 · USA</p>
      </div>
       <!-- Conference Information Card -->
<div class="max-w-3xl mx-auto mt-16">

  <div class="rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900 p-6 shadow-sm">

    <p class="text-sm text-center text-gray-600 dark:text-gray-400 mb-3 ">
      <strong>Last Updated:</strong> October 2025
    </p>

    <p class="text-sm text-center text-gray-700 dark:text-gray-300 leading-relaxed">
      <strong>Note:</strong> The entries listed on this page include selected
      conference presentations, invited talks, symposium contributions,
      and guest lectures delivered by the Founder of the
      <strong>Smart, Health, AI, and Leadership Lab (SHAIL Lab)</strong>.
      These activities represent scholarly dissemination and academic
      engagement at international conferences and professional events.
      Not all conference presentations are associated with peer-reviewed
      proceedings or published papers.
    </p>

  </div>
</div>
      
  </section>
</Layout>
