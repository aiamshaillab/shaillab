---
import Layout from '~/layouts/PageLayout.astro';
import Teamset from '~/components/widgets/Teamset.astro';

import { getPermalink } from '~/utils/permalinks';

import avatar0 from '~/assets/images/avatar.jpg';
import neama from '~/assets/images/neama ali.jpg';
import maytacha from '~/assets/images/maytacha.jpg';
import joy from '~/assets/images/joy.jpg';
import hanh from '~/assets/images/dtmh.png';
import luk from '~/assets/images/lukman.jpg';
import khalid from '~/assets/images/khalid.jpeg';
import bashir from '~/assets/images/bashir.jpeg';
import 範玉清偉 from '~/assets/images/avtgrl.png';
import MohammadShadmanShafat from '~/assets/images/avtboy.png';
import 譚惠琳 from '~/assets/images/avtgrl2.png';
import LouiseKhateValienteContreras from '~/assets/images/avtboy2.png';
import 李彬 from '~/assets/images/avtboy3.png';
import YanisaChuenopparat from '~/assets/images/yanisachuenopparat.jpg';
import PhamNgocThanhVy from '~/assets/images/phamngocthanhvy.jpg';
const metadata = {
  title: 'Our Lab Members',
};
---

<Layout metadata={metadata}>
  <!-- =========================
     Founder & Director (Centered + Avatar under name)
     ========================= -->
  <section class="bg-white dark:bg-slate-950">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 pt-10 pb-12 sm:pt-12 sm:pb-14">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold tracking-wide text-accent uppercase">Founder &amp; Director</p>

        <h1 class="mt-3 text-4xl sm:text-5xl font-bold tracking-tight text-gray-900 dark:text-white">
          Dr. <span class="text-accent dark:text-white">Yankuba B. Manga</span>
        </h1>

        {/* ✅ Profile image directly under the name (like your circle example) */}
        <img
          src={avatar0.src}
          alt="Dr. Yankuba B. Manga – Founder & Director, SHAIL Lab"
          loading="eager"
          class="mx-auto mt-6 h-44 w-44 sm:h-52 sm:w-52 rounded-full object-cover object-top
               shadow-lg ring-4 ring-white/90 dark:ring-slate-900/80"
        />

        {/* Text (same text, just cleaner spacing) */}
        <p class="mt-6 mx-auto max-w-2xl text-base sm:text-lg leading-relaxed text-gray-700 dark:text-gray-300">
          Dr. Manga is the Founder &amp; Director of <span class="font-semibold">SHAIL Lab</span> and an Assistant Professor
          at National Taipei University.
        </p>

        <p class="mt-4 mx-auto max-w-2xl text-base sm:text-lg leading-relaxed text-gray-700 dark:text-gray-300">
          His research spans artificial intelligence, healthcare management, wearable technologies, and data-driven
          innovation, with a mission to transform smart systems into responsible, scalable solutions for global health.
        </p>

        {/* Button */}
        <div class="mt-7 flex justify-center">
          <a
            href={getPermalink('/founder/info')}
            class="inline-flex items-center justify-center rounded-full px-7 py-3 text-sm font-semibold
                 bg-primary text-white shadow-sm transition hover:opacity-90 focus:outline-none
                 focus:ring-2 focus:ring-primary/40"
          >
            Read Full Profile
          </a>
        </div>
      </div>
    </div>
  </section>
  <!-- =========================
     LAB MEMBERS
     ========================= -->

  <section class="py-14 md:py-16">
    <!-- Section Title -->
    <div class="text-center mb-10">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white">Our Lab Members</h2>
      <p class="mt-2 text-sm font-semibold text-blue-600 tracking-widest uppercase">Current Members</p>
    </div>

    <!-- Team Members -->
    <Teamset
