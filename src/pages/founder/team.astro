  <section class="py-10 md:py-12 bg-gray-50 dark:bg-gray-800">
    <div class="mx-auto max-w-3xl px-4 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold tracking-tight text-gray-900 dark:text-white">
        SHAIL Lab Alumni
      </h2>
      <p class="mt-3 text-base sm:text-lg text-gray-600 dark:text-gray-300 leading-relaxed">
        Meet our graduated members and their current positions.
      </p>
      <div class="mt-6">
        <a
          href={getPermalink('/founder/alumni')}
          class="inline-flex items-center gap-2 rounded-full bg-primary px-7 py-3 text-sm font-semibold
