---
import Layout from '~/layouts/PageLayout.astro';
const metadata = {
  title: 'Contact Form | SHAIL Lab',
  description:
    'Use this form when you are unsure which inbox to choose. We will route your message internally. Please also review our FAQs for common enquiries.',
};

// ✅ Your real Formspree form ID (from https://formspree.io/f/xvzokooo)
const FORMSPREE_FORM_ID = 'xvzokooo';

// Optional: show a success message after redirect: /founder/contact_form?success=true
const success = Astro.url.searchParams.get('success') === 'true';
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-5xl px-4 py-16 sm:py-20">
    <header class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-semibold tracking-wide text-accent">Contact Form</p>
      <h1 class="mt-2 text-3xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-4xl">
        Send an enquiry to SHAIL Lab
      </h1>
      <p class="mt-3 text-base leading-relaxed text-gray-600 dark:text-gray-300">
        Use this form when you are unsure which inbox to choose. We will route your message internally.
      </p>

      {
        success && (
          <div
            class="mt-6 rounded-2xl border border-emerald-200 bg-emerald-50 px-5 py-4 text-left text-sm text-emerald-900 dark:border-emerald-900/40 dark:bg-emerald-950/20 dark:text-emerald-200"
            role="status"
            aria-live="polite"
          >
            <p class="font-semibold">Thank you—your message has been received.</p>
            <p class="mt-1">
              You will receive an acknowledgement by email. We typically reply within{' '}
              <span class="font-medium">2–3 business days</span>.
            </p>
          </div>
        )
      }
    </header>

    <div class="mx-auto mt-10 max-w-3xl">
      <div
        class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-800 dark:bg-slate-900 sm:p-10"
      >
        <form method="POST" action={`https://formspree.io/f/${FORMSPREE_FORM_ID}`} class="space-y-8">
          <!-- Formspree metadata -->
          <input type="hidden" name="_subject" value="New Contact Enquiry – SHAIL Lab" />
          <input type="hidden" name="_template" value="table" />
          <input type="hidden" name="_redirect" value="/founder/contact_form?success=true" />

          <!-- Required fields -->
          <section aria-labelledby="required-fields" class="space-y-6">
            <div class="flex items-center justify-between gap-3">
              <h2 id="required-fields" class="text-base font-semibold text-gray-900 dark:text-white">
                Required fields
              </h2>
              <span class="text-xs text-gray-500 dark:text-gray-400">Fields marked with * are required.</span>
            </div>

            <div class="grid gap-6 sm:grid-cols-2">
              <div class="sm:col-span-1">
                <label for="name" class="mb-2 block text-sm font-medium text-gray-900 dark:text-white">
                  Full name <span class="text-red-500">*</span>
                </label>
                <input
                  id="name"
                  name="name"
                  type="text"
                  required
                  autocomplete="name"
                  placeholder="e.g., John Doe"
                  class="field"
                />
              </div>

              <div class="sm:col-span-1">
                <label for="affiliation" class="mb-2 block text-sm font-medium text-gray-900 dark:text-white">
                  Institutional / organization affiliation
                </label>
                <input
                  id="affiliation"
                  name="affiliation"
                  type="text"
                  autocomplete="organization"
                  placeholder="e.g., National Taipei University"
                  class="field"
                />
              </div>
            </div>

            <div class="grid gap-6 sm:grid-cols-2">
              <div class="sm:col-span-1">
                <label for="email" class="mb-2 block text-sm font-medium text-gray-900 dark:text-white">
                  Email address <span class="text-red-500">*</span>
                </label>
                <input
                  id="email"
                  name="email"
                  type="email"
                  required
                  autocomplete="email"
                  placeholder="e.g., name@example.com"
                  class="field"
                />
              </div>

              <div class="sm:col-span-1">
                <label for="topic" class="mb-2 block text-sm font-medium text-gray-900 dark:text-white">
                  Topic <span class="text-red-500">*</span>
                </label>
                <select id="topic" name="topic" required class="field">
                  <option value="">Select a topic</option>
                  <option>General enquiry</option>
                  <option>Collaboration &amp; partnerships</option>
                  <option>Technical &amp; research support</option>
                  <option>Media &amp; press</option>
                  <option>Other</option>
                </select>
              </div>
            </div>

            <div>
              <div class="flex items-center justify-between gap-3">
                <label for="message" class="mb-2 block text-sm font-medium text-gray-900 dark:text-white">
                  Message <span class="text-red-500">*</span>
                </label>
                <span id="counter" class="text-xs text-gray-500 dark:text-gray-400">0 / 2000</span>
              </div>
              <textarea
                id="message"
                name="message"
                rows="6"
                maxlength="2000"
                required
                placeholder="Briefly describe your enquiry (maximum 2,000 characters)"
                class="field"></textarea>
              <p class="mt-2 text-xs text-gray-500 dark:text-gray-400">
                Please avoid sharing sensitive personal data unless necessary.
              </p>
            </div>
          </section>

          <!-- Optional fields -->
          <section aria-labelledby="optional-fields" class="space-y-6">
            <h2 id="optional-fields" class="text-base font-semibold text-gray-900 dark:text-white">Optional fields</h2>

            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <label for="country" class="mb-2 block text-sm font-medium text-gray-900 dark:text-white">
                  Country / region
                </label>
                <input id="country" name="country" type="text" placeholder="e.g., Taiwan" class="field" />
              </div>

              <div>
                <label for="phone" class="mb-2 block text-sm font-medium text-gray-900 dark:text-white">
                  Phone number
                </label>
                <input
                  id="phone"
                  name="phone"
                  type="tel"
                  autocomplete="tel"
                  placeholder="e.g., +886 ..."
                  class="field"
                />
              </div>
            </div>

            <div>
              <label for="urls" class="mb-2 block text-sm font-medium text-gray-900 dark:text-white">
                Relevant URLs (project page, dataset, preprint, etc.)
              </label>
              <input
                id="urls"
                name="urls"
                type="url"
                placeholder="e.g., https://github.com/... or https://doi.org/..."
                class="field"
              />
            </div>

            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <label for="meeting_mode" class="mb-2 block text-sm font-medium text-gray-900 dark:text-white">
                  Preferred meeting mode
                </label>
                <select id="meeting_mode" name="meeting_mode" class="field">
                  <option value="">No preference</option>
                  <option>In-person</option>
                  <option>Google Meet</option>
                  <option>Zoom</option>
                  <option>Microsoft Teams</option>
                </select>
              </div>

              <div>
                <label for="availability" class="mb-2 block text-sm font-medium text-gray-900 dark:text-white">
                  Earliest availability (UTC+8)
                </label>
                <input
                  id="availability"
                  name="availability"
                  type="text"
                  placeholder="e.g., 2026-01-05 14:00"
                  class="field"
                />
              </div>
            </div>
          </section>

          <!-- Consent -->
          <section aria-labelledby="consent" class="space-y-4">
            <h2 id="consent" class="text-base font-semibold text-gray-900 dark:text-white">Consent</h2>

            <div
              class="rounded-2xl border border-gray-200 bg-gray-50 p-5 dark:border-gray-800 dark:bg-slate-950 space-y-4"
            >
              <label class="flex gap-3 text-sm text-gray-700 dark:text-gray-300">
                <input
                  type="checkbox"
                  name="agree_legal"
                  required
                  class="mt-1 h-4 w-4 rounded border-gray-300 text-accent focus:ring-accent"
                />
                <span>
                  I have read and agree to the
                  <a href="/founder/terms" class="font-medium text-accent underline underline-offset-4">
                    Terms of Use
                  </a>,
                  <a href="/founder/privacy" class="font-medium text-accent underline underline-offset-4">
                    Privacy Policy
                  </a>, and
                  <a href="/founder/faqs" class="font-medium text-accent underline underline-offset-4"> FAQs </a>.
                  <span class="text-red-500"> *</span>
                </span>
              </label>

              <label class="flex gap-3 text-sm text-gray-700 dark:text-gray-300">
                <input
                  type="checkbox"
                  name="consent_processing"
                  required
                  class="mt-1 h-4 w-4 rounded border-gray-300 text-accent focus:ring-accent"
                />
                <span>
                  I consent to SHAIL Lab processing my personal data for the purpose of handling this enquiry.
                  <span class="text-red-500"> *</span>
                </span>
              </label>

              <label class="flex gap-3 text-sm text-gray-700 dark:text-gray-300">
                <input
                  type="checkbox"
                  name="subscribe"
                  class="mt-1 h-4 w-4 rounded border-gray-300 text-accent focus:ring-accent"
                />
                <span>
                  I would like to receive occasional news and events from SHAIL Lab. I understand I can unsubscribe at
                  any time.
                </span>
              </label>
            </div>

            <!-- ✅ Single Actions block (deduplicated) -->
            <section class="flex flex-col items-center gap-3 pt-2 sm:flex-row sm:justify-center">
              <button type="submit" class="btn btn-primary">Submit-Form</button>
              <button type="reset" class="btn btn-secondary">Reset-Form</button>
            </section>

            <!-- ✅ Single microcopy (deduplicated) -->
            <p class="pt-2 text-center text-sm text-gray-500 dark:text-gray-400">
              After submitting, you will receive an acknowledgement by email. We typically reply within 2–3 business
              days.
            </p>
          </section>
        </form>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Lightweight counter (no framework)
  const textarea = document.getElementById('message');
  const counter = document.getElementById('counter');
  if (textarea && counter) {
    const update = () => (counter.textContent = `${textarea.value.length} / 2000`);
    textarea.addEventListener('input', update);
    update();
  }
</script>

<style>
  /* Clean, consistent field styling */
  .field {
    width: 100%;
    border-radius: 0.9rem;
    border: 1px solid rgb(209 213 219);
    background: #fff;
    padding: 0.8rem 1rem;
    font-size: 0.95rem;
    line-height: 1.25rem;
    transition:
      box-shadow 180ms ease,
      border-color 180ms ease,
      background 180ms ease;
    outline: none;
  }
  .field:focus {
    border-color: rgba(109, 40, 217, 0.65);
    box-shadow: 0 0 0 4px rgba(109, 40, 217, 0.18);
  }
  .field::placeholder {
    color: rgb(156 163 175);
  }

  :global(.dark) .field {
    background: rgb(2 6 23);
    border-color: rgb(55 65 81);
    color: #fff;
  }
  :global(.dark) .field::placeholder {
    color: rgb(148 163 184);
  }
  :global(.dark) .field:focus {
    border-color: rgba(167, 139, 250, 0.7);
    box-shadow: 0 0 0 4px rgba(167, 139, 250, 0.18);
  }

  .btn {
    border-radius: 0.85rem;
    padding: 0.8rem 1.3rem;
    font-weight: 700;
    font-size: 0.95rem;
    transition:
      transform 120ms ease,
      opacity 120ms ease,
      box-shadow 180ms ease;
  }
  .btn:active {
    transform: translateY(1px);
  }
  .btn-primary {
    background: rgb(109 40 217);
    color: #fff;
    box-shadow: 0 10px 25px rgba(109, 40, 217, 0.25);
  }
  .btn-primary:hover {
    opacity: 0.95;
  }
  .btn-secondary {
    background: transparent;
    color: rgb(109 40 217);
    border: 1px solid rgba(109, 40, 217, 0.45);
  }
  .btn-secondary:hover {
    box-shadow: 0 0 0 4px rgba(109, 40, 217, 0.14);
  }

  :global(.dark) .btn-secondary {
    color: rgb(167 139, 250);
    border-color: rgba(167 139 250, 0.45);
  }
</style>
