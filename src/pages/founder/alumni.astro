---
import Layout from '~/layouts/PageLayout.astro';
import Teamset from '~/components/widgets/Teamset.astro';

import { getPermalink } from '~/utils/permalinks';
import giulia from '~/assets/images/giulia.jpg';
import harry from '~/assets/images/harry.jpg';
import avatar0 from '~/assets/images/avatar.jpg';
import airam from '~/assets/images/airam.jpg';
import hesti from '~/assets/images/hesti.jpg';

const metadata = {
  title: 'SHAIL Lab Alumni',
};
---

<Layout metadata={metadata}>
  <!-- =========================
     Founder & Director (Centered + Avatar under name)
     ========================= -->
<section class="bg-white dark:bg-slate-950">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 pt-10 pb-12 sm:pt-12 sm:pb-14">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-semibold tracking-wide text-accent uppercase">Founder &amp; Director</p>

      <h1 class="mt-3 text-4xl sm:text-5xl font-bold tracking-tight text-gray-900 dark:text-white">
        Dr. <span class="text-accent dark:text-white">Yankuba B. Manga</span>
      </h1>

      {/* ✅ Profile image directly under the name (like your circle example) */}
      <img
        src={avatar0.src}
        alt="Dr. Yankuba B. Manga – Founder & Director, SHAIL Lab"
        loading="eager"
        class="mx-auto mt-6 h-44 w-44 sm:h-52 sm:w-52 rounded-full object-cover object-top
               shadow-lg ring-4 ring-white/90 dark:ring-slate-900/80"
      />

      {/* Text (same text, just cleaner spacing) */}
      <p class="mt-6 mx-auto max-w-2xl text-base sm:text-lg leading-relaxed text-gray-700 dark:text-gray-300">
        Dr. Manga is the Founder &amp; Director of <span class="font-semibold">SHAIL Lab</span> and an Assistant Professor
        at National Taipei University.
      </p>

      <p class="mt-4 mx-auto max-w-2xl text-base sm:text-lg leading-relaxed text-gray-700 dark:text-gray-300">
        His research spans artificial intelligence, healthcare management, wearable technologies, and data-driven
        innovation, with a mission to transform smart systems into responsible, scalable solutions for global
        health.
      </p>

      {/* Button */}
      <div class="mt-7 flex justify-center">
        <a
          href={getPermalink('/founder/info')}
          class="inline-flex items-center justify-center rounded-full px-7 py-3 text-sm font-semibold
                 bg-primary text-white shadow-sm transition hover:opacity-90 focus:outline-none
                 focus:ring-2 focus:ring-primary/40"
        >
          Read Full Profile
        </a>
      </div>
    </div>
  </div>
</section>
<!-- =========================
     ALUMNI / FORMER MEMBERS
     ========================= -->

  <section class="py-14 md:py-16">
    <!-- Section Title -->
    <div class="text-center mb-10">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white">Alumni of SHAIL Lab</h2>

      <p class="mt-2 text-sm font-semibold text-blue-600 tracking-widest uppercase">Former Members</p>
    </div>

    <Teamset
      prices={[
         {
          title: 'Hesti Pawarti',
          subtitle: 'MSc. Smart Healthcare Management',
          image: hesti,
          content: 'Artificial Intelligence in Skincare Solutions',
          contact: 'pawartihesti@gmail.com',
          date: 'ADVISOR: May 2024 - Jul 2025',
          hasRibbon: true,
          ribbonTitle: '🎓 Graduated',
        },
        {
          title: 'Giulia Bianchini',
          subtitle: 'MSc. Smart Healthcare Management',
          image: giulia,
          content:
            'Effectiveness and Challenges of AI in Emergency Care Decision-Making: A Systematic Literature Review',
          contact: 'giulia.bianchini@example.com',
          date: 'ADVISOR: May 2024 - Jul 2025',
          hasRibbon: true,
          ribbonTitle: '🎓 Graduated',
        },
           {
          title: 'Mai Xuan Hao',
          subtitle: 'MSc. Smart Healthcare Management',
          image: harry,
          content: 'Current Position: Medical Data Operator & Analyst Specialist at Gene Solutions',
          contact: 'xuanhaomai.95@gmail.com',
          date: 'ADVISOR: Sep 2023 - Jul 2024',
          hasRibbon: true,
          ribbonTitle: '🎓 Graduated',
        },
        {
          title: 'Cao Thi Thuy Duong',
          subtitle: 'MSc. Smart Healthcare Management',
          image: airam,
          content: 'Current Position: Quality Assurance at YUNGSHIN PHARM. IND. CO. LTD 永信藥品工業股份有限公司',
          contact: 'duongctt.pmc@gmail.com',
          date: 'ADVISOR: Sep 2023 - Jul 2024',
          hasRibbon: true,
          ribbonTitle: '🎓 Graduated',
        },

      ]}
    />
  </section>

</Layout>
