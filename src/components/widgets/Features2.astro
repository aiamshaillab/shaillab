---
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Headline from '~/components/ui/Headline.astro';
import ItemGrid2 from '~/components/ui/ItemGrid2.astro';
import type { Features as Props } from '~/types';

const {
  title = await Astro.slots.render('title'),
  subtitle = await Astro.slots.render('subtitle'),
  tagline = await Astro.slots.render('tagline'),
  items = [],
  columns = 3,
  defaultIcon,

  id,
  isDark = false,
  classes = {},
  bg = await Astro.slots.render('bg'),

  // ✅ NEW: compact spacing toggle
  compact = false,
} = Astro.props as Props & { compact?: boolean };

// ✅ NEW: override WidgetWrapper padding via containerClass (twMerge will resolve conflicts)
const compactPadding = compact ? 'py-6 md:py-8 lg:py-10' : '';
---

<WidgetWrapper
  id={id}
  isDark={isDark}
  bg={bg}
  containerClass={`
    max-w-7xl mx-auto
    ${compactPadding}   /* ✅ overrides default py-12/md:py-16/lg:py-20 when compact=true */
    ${classes?.container ?? ''}
  `}
>
  <Headline
    title={title}
    subtitle={subtitle}
    tagline={tagline}
    classes={classes?.headline as Record<string, string>}
  />

  <ItemGrid2
    items={items}
    columns={columns}
    defaultIcon={defaultIcon}
    classes={{
      // ✅ NEW: slightly tighter spacing in compact mode
      container: compact ? 'gap-4 md:gap-5 mt-6' : 'gap-4 md:gap-6 mt-8',
      panel:
        'rounded-lg shadow-[0_4px_30px_rgba(0,0,0,0.1)] dark:shadow-[0_4px_30px_rgba(0,0,0,0.1)] backdrop-blur border border-[#ffffff29] bg-white dark:bg-slate-900 p-6',
      icon: 'w-12 h-12 mb-6 text-primary',
      ...((classes?.items as Record<string, never>) ?? {}),
    }}
  />
</WidgetWrapper>
