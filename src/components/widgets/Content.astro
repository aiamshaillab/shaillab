---
import type { Content as Props } from '~/types';
import Headline from '~/components/ui/Headline.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Image from '~/components/common/Image.astro';
import Button from '~/components/ui/Button.astro';
import ItemGrid from '~/components/ui/ItemGrid.astro';

const {
  title = await Astro.slots.render('title'),
  subtitle = await Astro.slots.render('subtitle'),
  tagline,
  content = await Astro.slots.render('content'),
  callToAction,
  items = [],
  columns,
  image = await Astro.slots.render('image'),
  isReversed = false,
  isAfterContent = false,

  id,
  isDark = false,
  classes = {},
  bg = await Astro.slots.render('bg'),
} = Astro.props as Props;

// ---------- helpers ----------
const str = (v: unknown) => (typeof v === 'string' ? v.trim() : '');
const hasStr = (v: unknown) => str(v).length > 0;

const pickStr = (obj: unknown, key: string) =>
  obj && typeof obj === 'object' && typeof (obj as Record<string, unknown>)[key] === 'string'
    ? ((obj as Record<string, unknown>)[key] as string)
    : '';

const pickObj = (obj: unknown, key: string) =>
  obj && typeof obj === 'object' && (obj as Record<string, unknown>)[key] && typeof (obj as Record<string, unknown>)[key] === 'object'
    ? ((obj as Record<string, unknown>)[key] as Record<string, string>)
    : ({} as Record<string, string>);

// Normalize rendered slots (they often include whitespace)
const titleStr = str(title);
const subtitleStr = str(subtitle);
const taglineStr = str(tagline);
const contentStr = str(content);

// image can be an HTML string slot or an object passed from parent
const hasImage = typeof image === 'string' ? hasStr(image) : Boolean(image);
const hasHeadline = hasStr(titleStr) || hasStr(subtitleStr) || hasStr(taglineStr);
const hasContent = hasStr(contentStr);
const hasItems = Array.isArray(items) && items.length > 0;
const hasCTA = Boolean(callToAction);

// ✅ NEW: wrapper padding override controlled by classes.wrapper (string)
const wrapperClass = pickStr(classes, 'wrapper');

const headlineClasses = pickObj(classes, 'headline'); // Record<string,string>
const itemsClasses = pickObj(classes, 'items'); // Record<string,string>

// layout mode: only split into 2 columns if image exists
const wrapperLayoutClass = hasImage
  ? `md:flex md:gap-16 ${isReversed ? 'md:flex-row-reverse' : ''}`
  : `flex flex-col items-center`;

const leftColClass = hasImage ? 'md:basis-1/2 self-center' : 'w-full';

// Optional hooks (strings)
const contentClass = pickStr(classes, 'content');
const ctaContainerClass = pickStr(classes, 'ctaContainer');
---

<WidgetWrapper
  id={id}
  isDark={isDark}
  bg={bg}
  wrapperClass={wrapperClass}
  containerClass={`max-w-7xl mx-auto ${isAfterContent ? 'pt-0 md:pt-0 lg:pt-0' : ''} ${
    typeof (classes as any)?.container === 'string' ? (classes as any).container : ''
  }`}
>
  {hasHeadline && (
    <Headline
      title={titleStr}
      subtitle={subtitleStr}
      tagline={taglineStr}
      classes={{
        container: 'max-w-xl sm:mx-auto lg:max-w-2xl',
        title: 'text-4xl md:text-5xl font-bold tracking-tighter mb-4 font-heading',
        subtitle: 'max-w-3xl mx-auto sm:text-center text-xl text-muted dark:text-slate-400',
        ...headlineClasses,
      }}
    />
  )}

  <div class={`mx-auto max-w-7xl ${hasHeadline ? 'mt-6' : ''} px-4 md:px-8`}>
    <div class={wrapperLayoutClass}>
      {/* LEFT / MAIN */}
      <div class={leftColClass}>
        {hasContent && (
          <div
            class={`text-lg text-gray-700 dark:text-slate-300 ${hasImage ? 'mb-10' : 'mb-0'} ${contentClass}`}
            set:html={contentStr}
          />
        )}

        {hasCTA && (
          <div class={`mt-6 ${ctaContainerClass}`}>
            <Button variant="link" {...callToAction} />
          </div>
        )}

        {hasItems && (
          <ItemGrid
            items={items}
            columns={columns}
            defaultIcon="tabler:check"
            classes={{
              container: `mt-10 gap-y-4 md:gap-y-8 ${itemsClasses.container ?? ''}`,
              panel: `max-w-none ${itemsClasses.panel ?? ''}`,
              title: `text-lg font-medium leading-6 dark:text-white ml-2 rtl:ml-0 rtl:mr-2 ${itemsClasses.title ?? ''}`,
              description: `text-muted dark:text-slate-400 ml-2 rtl:ml-0 rtl:mr-2 ${itemsClasses.description ?? ''}`,
              icon: `flex h-7 w-7 items-center justify-center rounded-full bg-green-600 dark:bg-green-700 text-gray-50 p-1 ${
                itemsClasses.icon ?? ''
              }`,
              action: `text-lg font-medium leading-6 dark:text-white ml-2 rtl:ml-0 rtl:mr-2 ${itemsClasses.action ?? ''}`,
            }}
          />
        )}
      </div>

      {/* RIGHT / IMAGE (only when image exists) */}
      {hasImage && (
        <div aria-hidden="true" class="mt-10 md:mt-0 md:basis-1/2">
          <div class="relative m-auto max-w-4xl">
            {typeof image === 'string' ? (
              <Fragment set:html={image} />
            ) : (
              <Image
                class="mx-auto w-full rounded-lg bg-gray-500 shadow-lg"
                width={500}
                height={500}
                widths={[400, 768]}
                sizes="(max-width: 768px) 100vw, 432px"
                layout="responsive"
                {...(image as any)}
              />
            )}
          </div>
        </div>
      )}
    </div>
  </div>
</WidgetWrapper>
