---
import type { ItemGrid as Props } from '~/types';
import { Icon } from 'astro-icon/components';
import { twMerge } from 'tailwind-merge';

const { items = [], columns, defaultIcon = '', classes = {} } = Astro.props;

const {
  container: containerClass = '',
  panel: panelClass = '',
  title: titleClass = '',
  description: descriptionClass = '',
  icon: defaultIconClass = 'text-primary',
} = classes;

const isExternal = (href: string) => /^https?:\/\//.test(href ?? '');
---

{
  items && items.length > 0 && (
    <div
      class={twMerge(
        `grid gap-8 gap-x-12 sm:gap-y-8 ${
          columns === 4
            ? 'lg:grid-cols-4 md:grid-cols-3 sm:grid-cols-2'
            : columns === 3
              ? 'lg:grid-cols-3 sm:grid-cols-2'
              : columns === 2
                ? 'sm:grid-cols-2'
                : ''
        }`,
        containerClass
      )}
    >
      {items.map((item) => {
        const { title, description, icon, classes: itemClasses = {} } = item;

        // ✅ Support both: item.link OR item.callToAction.href
        const href = (item as any)?.link ?? item?.callToAction?.href ?? '';
        const external = href && isExternal(href);
        const Tag: any = href ? 'a' : 'div';

        return (
          <Tag
            href={href || undefined}
            target={external ? '_blank' : undefined}
            rel={external ? 'noopener noreferrer' : undefined}
            class={twMerge(
              'relative flex flex-col intersect-once intersect-quarter intersect-no-queue motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade',
              panelClass,
              itemClasses?.panel,
              // ✅ Make the entire card feel clickable
              href
                ? 'block cursor-pointer transition hover:-translate-y-1 hover:shadow-lg focus:outline-none focus:ring-2 focus:ring-accent/40'
                : ''
            )}
          >
            {(icon || defaultIcon) && (
              <Icon
                name={icon || defaultIcon}
                class={twMerge('mb-2 w-10 h-10', defaultIconClass, itemClasses?.icon)}
              />
            )}

            {title && <div class={twMerge('text-xl font-bold', titleClass, itemClasses?.title)}>{title}</div>}

            {description && (
              <p class={twMerge('text-muted mt-2', descriptionClass, itemClasses?.description)} set:html={description} />
            )}

            {/* ✅ Button removed intentionally */}
          </Tag>
        );
      })}
    </div>
  )
}
