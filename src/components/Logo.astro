---
import logo from '~/assets/images/99.png';
---

<div class="flex items-center gap-2">
  <div class="h-12 w-12 rounded-full bg-white flex items-center justify-center shadow-md">
    <img
      src={logo.src}
      alt="SHAIL Lab Logo"
      class="h-8 w-8 object-contain"
    />
  </div>

  <span class="text-2xl font-bold text-white whitespace-nowrap">
    SHAIL LAB
  </span>
</div>


